# ============================================================
# VARIABLES DE ENTORNO — Vocaciones STEAM API
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a Git.
# ============================================================

# ----- Puertos de los microservicios -----
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_USERS=3002
PORT_TESTS=3003
PORT_AI=3004
PORT_MAIL=3005

# ----- Hosts TCP de los microservicios -----
# En local: 127.0.0.1 (todos corren en la misma máquina)
# En Railway: el hostname privado de cada servicio (e.g. auth.railway.internal)
HOST_AUTH=127.0.0.1
HOST_USERS=127.0.0.1
HOST_TESTS=127.0.0.1
HOST_AI=127.0.0.1
HOST_MAIL=127.0.0.1

# ----- Base de datos (Railway provee DATABASE_URL automáticamente) -----
# Si DATABASE_URL está definido, se ignoran las variables DB_* individuales
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TuPasswordSegura
DB_NAME=steam_vocations

# ----- JWT -----
JWT_SECRET=reemplaza_con_un_secreto_largo_y_aleatorio

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tuClientSecret

# ----- Gemini AI -----
GEMINI_API_KEY=AIzaSyTuClaveRealDeGemini

# ----- CORS (URL de tu frontend Angular) -----
# En producción: https://tu-frontend.vercel.app
# En local: * (sin restricción)
CORS_ORIGIN=*
