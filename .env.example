# ============================================================
# VARIABLES DE ENTORNO — Vocaciones STEAM API
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a Git.
# ============================================================

# ----- Puertos de los microservicios -----
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_USERS=3002
PORT_TESTS=3003
PORT_AI=3004
PORT_MAIL=3005

# ----- Hosts TCP de los microservicios -----
HOST_AUTH=127.0.0.1
HOST_USERS=127.0.0.1
HOST_TESTS=127.0.0.1
HOST_AI=127.0.0.1
HOST_MAIL=127.0.0.1

# ----- Base de datos -----
DATABASE_URL=
DB_SSL=false
DB_SYNCHRONIZE=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TuPasswordSegura
DB_NAME=steam_vocations

# ----- JWT -----
JWT_SECRET=reemplaza_con_un_secreto_largo_y_aleatorio

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tuClientSecret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:4200/login
CORS_ORIGIN=http://localhost:4200,https://vocaciones-steam.vercel.app

# ----- Groq AI (A8: matching de universidades) -----
GROQ_API_KEY=

# ----- Motor Vocacional FastAPI (A0-A8) -----
# URL pública del servicio motor-vocacional-api desplegado en Railway.
MOTOR_VOCACIONAL_URL=
# Debe coincidir con MOTOR_API_KEY configurada en el servicio FastAPI.
MOTOR_VOCACIONAL_API_KEY=

# ----- Mail Service (Brevo API) -----
BREVO_API_KEY=tu-api-key-de-brevo

# ----- CORS -----
CORS_ORIGIN=*

# ----- Google Maps (A8: distancia real; sin clave se usa haversine) -----
GOOGLE_MAPS_API_KEY=

# ----- Google Places (descubrimiento de universidades, panel admin) -----
GOOGLE_PLACES_API_KEY=

# ----- INEGI DENUE (descubrimiento de universidades vía censo económico oficial) -----
INEGI_DENUE_TOKEN=
